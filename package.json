{
  "name": "would-you-dao",
  "version": "0.1.0",
  "description": "A private A/B balance-game DAO on Solana, sealed by Arcium encrypted computation.",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "test": "node tests/smoke.test.js",
    "check": "node tests/smoke.test.js && tsc --noEmit",
    "build:site-crypto": "esbuild site/src/arcium-vote-client.js --bundle --format=iife --global-name=CipherDaoCrypto --alias:crypto=./site/src/node-crypto-shim.js --outfile=site/vendor/arcium-vote.js",
    "dao:bootstrap": "tsx app/scripts/bootstrapDao.ts",
    "dao:vote": "tsx app/scripts/castVote.ts",
    "dao:tally": "tsx app/scripts/publishTally.ts",
    "deploy:devnet": "scripts/deploy-devnet.sh"
  },
  "keywords": [
    "arcium",
    "solana",
    "dao",
    "governance",
    "mpc",
    "privacy"
  ],
  "dependencies": {
    "@arcium-hq/client": "^0.9.7",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
