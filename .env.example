RPC_URL=https://api.devnet.solana.com
KEYPAIR=/Users/jaehong/.config/solana/id.json
# For Vercel/serverless deployments, prefer one of these instead of a local file path.
# KEYPAIR_JSON=[1,2,3,...]
# KEYPAIR_BASE64=base64-encoded-solana-keypair-json
ARCIUM_CLUSTER_OFFSET=456
SITE_STATE_PATH=artifacts/site-proposals.json

# Optional durable metadata storage. Server-side only.
DATABASE_URL=postgresql://postgres.project:password@aws-region.pooler.supabase.com:5432/postgres
# POSTGRES_URL can be used instead of DATABASE_URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_STATE_TABLE=would_you_dao_state
SUPABASE_STATE_ID=production

# Optional Mac DAO server integrations.
REMOTE_IMAGE_GENERATOR_URL=http://PRIVATE_GPU_IP:7861/generate
IMAGE_GENERATOR_TOKEN=would-you-dao-local
IMAGE_GENERATION_SIZE=384
ENABLE_IMAGE_GENERATION=0
DEEPL_API_KEY=replace-with-your-deepl-key
TRANSLATION_TIMEOUT_MS=30000

# Optional Windows/local GPU bridge settings.
IMAGE_GENERATOR_HOST=127.0.0.1
IMAGE_GENERATOR_PORT=7861
SD_WEBUI_URL=http://127.0.0.1:7860
PROPOSAL_TITLE=Fund confidential governance grants
PROPOSAL_ID=1005
CLOSES_IN_SECONDS=259200
