{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "{app/**,scripts/load-env.js,site/src/dilemmas.js}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.(?:html|css|js|png|jpg|jpeg|webp|svg|ico))",
      "dest": "/site/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/site/index.html"
    }
  ]
}
